# Supabase (Postgres + Auth). Without these, the app runs fully client-side
# (localStorage) and Supabase reads/writes are skipped.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Vertex AI (Gemini), called via the Vercel AI SDK. Without these, the
# prioritization step falls back to a deterministic mock that matches the same
# output shape (see src/lib/llm/prioritize.ts).
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
# One of the two auth options below:
GOOGLE_VERTEX_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Defaults to gemini-2.5-flash if unset.
VERTEX_MODEL_ID=
