# Supabase (Postgres + Auth). Required -- auth and all app data depend on these.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Not read by app code yet; reserved for future admin-only server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Google Vertex AI (Gemini), called via the Vercel AI SDK. Without these, the
# prioritization step falls back to a deterministic mock that matches the same
# output shape (see src/lib/llm/prioritize.ts).
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
# One of the three auth options below:
GOOGLE_VERTEX_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# ...or a client_email/private_key pair from a service account key:
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Defaults to gemini-2.5-flash if unset.
VERTEX_MODEL_ID=
